# 建置階段
FROM node:20-alpine AS builder

WORKDIR /app

# 複製 package 檔案
COPY package*.json ./

# 安裝依賴
RUN npm ci

# 複製原始碼
COPY . .

# 建置前端
RUN npm run build

# 生產階段 - 使用 nginx
FROM nginx:alpine

# 複製建置好的前端檔案到 nginx
COPY --from=builder /app/dist /usr/share/nginx/html

# 複製 nginx 配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

# 暴露埠號
EXPOSE 80

# 啟動 nginx
CMD ["nginx", "-g", "daemon off;"]
